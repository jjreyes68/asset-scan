    ).join('');

    const header=document.createElement('div');
    header.className='crew-week-header';
    header.innerHTML=`
      <span class="wk-num">Wk ${w+1}</span>
      <span class="wk-dates">${getWeekDates(w)}</span>
      <span class="wk-half"><span class="wk-half-label fh-lbl">FH</span>${fhHTML}</span>
      <span class="wk-half"><span class="wk-half-label bh-lbl">BH</span>${bhHTML}</span>
      <span class="chevron">▼</span>
    `;
    header.addEventListener('click',()=>{
      weekEl.classList.toggle('open');
    });

    const daysEl=document.createElement('div');
    daysEl.className='crew-days';

    const weekStart=getWeekStart(w);
    for(let d=0;d<7;d++){
      const dayDate=addDays(weekStart,d);
      const dateStr=fmtDateISO(dayDate);
      const crew=getCrewForDay(w,d);
      const coverage=getCoverageForDate(dateStr);
      const dayEl=document.createElement('div');
      dayEl.className='crew-day';

      // Use effective crew — covers removed, cover people injected in their role
      const effectiveCrew=getEffectiveCrewForDay(w,d,dateStr);
      const slotsHTML=effectiveCrew.length>0
        ? effectiveCrew.map(p=>{
            let slotHTML;
            if(p.covering){
              slotHTML=`
                <span class="person-slot clickable" data-person="${p.name}" data-date="${dateStr}" style="background:var(--green-light);color:var(--green-dark);border:1px solid var(--green-mid);">
                  <span class="ps-name">${p.name}</span>
                  <span class="ps-role">${p.role} ↔ ${p.coveringFor}</span>
                </span>`;
            } else {
              slotHTML=`
                <span class="person-slot ps-${ROLE_CLS[p.role]} clickable" data-person="${p.name}" data-date="${dateStr}">
                  <span class="ps-name">${p.name}</span>
                  <span class="ps-role">${p.role}</span>
                </span>`;
            }
            return slotHTML;
          }).join('')
        : `<span class="no-crew">no coverage</span>`;

      dayEl.innerHTML=`
        <div class="crew-day-label">
          <span class="day-name">${DAY_NAMES[d]}</span>
          <span class="day-date">${fmtDate(dayDate)}</span>
        </div>
        <div class="crew-day-slots">${slotsHTML}</div>
      `;
      daysEl.appendChild(dayEl);
    }
    
    // Add click handlers to person slots
    daysEl.querySelectorAll('.clickable').forEach(slot=>{
      slot.addEventListener('click', ()=>{
        const personName=slot.dataset.person;
        const dateStr=slot.dataset.date;
        const timeOff=getTimeOffForPerson(personName, dateStr);
        openModal(personName, dateStr, timeOff);
      });
    });

    weekEl.appendChild(header);
    weekEl.appendChild(daysEl);
    grid.appendChild(weekEl);
  }
}

// Expand / collapse all
document.getElementById('expand-all').addEventListener('click',()=>{
  document.querySelectorAll('.crew-week').forEach(el=>el.classList.add('open'));
});
document.getElementById('collapse-all').addEventListener('click',()=>{
  document.querySelectorAll('.crew-week').forEach(el=>el.classList.remove('open'));
});

// Jump to week
document.getElementById('jump-input').addEventListener('keydown',e=>{
  if(e.key!=='Enter') return;
  const val=e.target.value.trim();
  let weekIdx=-1;
  // Try plain number first
  const num=parseInt(val);
  if(!isNaN(num) && num>=1 && num<=52){ weekIdx=num-1; }
  else {
    // Try date like 9/5 or 9/5/2025
    const parts=val.split('/');
    if(parts.length>=2){
      const month=parseInt(parts[0])-1;
      const day=parseInt(parts[1]);
      const year=parts[2]?parseInt(parts[2]):2025;
      const target=new Date(year,month,day);
      for(let w=0;w<52;w++){
        const ws=getWeekStart(w);
        const we=addDays(ws,6);
        if(target>=ws && target<=we){ weekIdx=w; break; }
      }
    }
  }
  if(weekIdx>=0){
    const el=document.querySelector(`.crew-week[data-week="${weekIdx}"]`);
    if(el){
      el.classList.add('open');
      el.scrollIntoView({behavior:'smooth',block:'start'});
    }
  }
  e.target.value='';
});

// Tab switching
document.querySelectorAll('.tab-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(`tab-${btn.dataset.tab}`).classList.add('active');
    
    // Render calendar when switching to that tab
    if(btn.dataset.tab === 'calendar'){
      renderCalendar();
    }
    // Render time-off list when switching to that tab
    if(btn.dataset.tab === 'timeoff'){
      renderTimeOffList();
    }
  });
});

// Initialize Firestore listener (with delay to ensure Firebase is loaded)
setTimeout(()=>{
  initFirestoreListener();
}, 500);

renderChips();
