<script>
const START = new Date('2025-08-03T12:00:00');
const ROLES = ['D1','D2','D3','N1','N2'];
const ROLE_CLS = {D1:'d1',D2:'d2',D3:'d3',N1:'n1',N2:'n2'};
const DAY_NAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

const state = {
  fh: ['Josh','Ricky','Christian','Sergio','Jesse'],
  bh: ['Morgan','Alex','Adam','Rob','FNG'],
  selected: '',
  timeOffRequests: [],
  modalState: {
    isOpen: false,
    type: 'vacation',
    person: '',
    startDate: '',
    endDate: '',
    coverage: [],
    coverageMode: 'auto',
    editingId: null
  },
  calendar: {
    currentMonth: new Date().getMonth(),
    currentYear: new Date().getFullYear()
  }
};

function getRoleForOp(posIdx, weekIdx){
  return ROLES[(posIdx + weekIdx) % 5];
}
function hasWed(half, weekIdx){
  return half==='fh' ? weekIdx%2===0 : weekIdx%2===1;
}
function getWeekStart(weekIdx){
  const d = new Date(START);
  d.setDate(d.getDate() + weekIdx*7);
  d.setHours(12,0,0,0);
  return d;
}
function getWeekDates(weekIdx){
  const d = getWeekStart(weekIdx);
  const e = new Date(d); e.setDate(e.getDate()+6);
  const f = dt => `${dt.getMonth()+1}/${dt.getDate()}`;
  return `${f(d)}–${f(e)}`;
}
function addDays(date, n){ const d=new Date(date); d.setDate(d.getDate()+n); return d; }
function fmtDate(d){ return `${d.getMonth()+1}/${d.getDate()}`; }
function fmtDateISO(d){ return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }

// --- Firestore Functions ---
function initFirestoreListener(){
  console.log('Initializing Firestore listener...');
  console.log('Firebase DB available:', !!window.firebaseDB);
  console.log('Firebase collection available:', !!window.firebaseCollection);
  console.log('Firebase query available:', !!window.firebaseQuery);
  console.log('Firebase onSnapshot available:', !!window.firebaseOnSnapshot);
  
  if(!window.firebaseDB){
    console.error('Firebase DB not available');
    alert('Firebase not initialized. Please refresh the page.');
    return;
  }
  
  try{
    const q = window.firebaseQuery(
      window.firebaseCollection(window.firebaseDB, 'timeOffRequests'),
      window.firebaseOrderBy('createdAt', 'desc')
    );
    console.log('Setting up snapshot listener...');
    window.firebaseOnSnapshot(q, (snapshot)=>{
      console.log('Snapshot received, docs:', snapshot.docs.length);
      state.timeOffRequests = snapshot.docs.map(doc=>({
        id: doc.id,
        ...doc.data()
      }));
      console.log('Time-off requests loaded:', state.timeOffRequests.length);
      console.log('Time-off requests data:', state.timeOffRequests);
      renderTable();
      renderCrewGrid();
      renderCalendar();
      renderTimeOffList();
    }, (error)=>{
      console.error('Snapshot listener error:', error);
      console.error('Error code:', error.code);
      console.error('Error message:', error.message);
    });
  }catch(e){
    console.error('Error setting up Firestore listener:', e);
    console.error('Error code:', e.code);
    console.error('Error message:', e.message);
  }
}

async function saveTimeOffRequest(data){
  console.log('Firebase DB available:', !!window.firebaseDB);
  if(!window.firebaseDB){
    alert('Firebase not initialized. Please check console for details.');
    return;
  }
  try{
    console.log('Saving time-off request:', data);
    if(data.id){
      console.log('Updating existing document:', data.id);
      await window.firebaseUpdateDoc(window.firebaseDoc(window.firebaseDB, 'timeOffRequests', data.id), {
        type: data.type,
        personName: data.personName,
        startDate: data.startDate,
        endDate: data.endDate,
        coverage: data.coverage,
        updatedAt: new Date().toISOString()
      });
      console.log('Update successful');
    }else{
      console.log('Creating new document');
      const docRef = await window.firebaseAddDoc(window.firebaseCollection(window.firebaseDB, 'timeOffRequests'), {
        type: data.type,
        personName: data.personName,
        startDate: data.startDate,
        endDate: data.endDate,
        coverage: data.coverage,
        status: 'approved',
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
      });
      console.log('Create successful, doc ID:', docRef.id);
    }
  }catch(e){
    console.error('Error saving time-off request:', e);
    console.error('Error code:', e.code);
    console.error('Error message:', e.message);
    alert(`Error saving time-off request: ${e.message}\n\nPlease check the browser console for more details.`);
  }
}

async function deleteTimeOffRequest(id){
  if(!window.firebaseDB) return;
  try{
    await window.firebaseDeleteDoc(window.firebaseDoc(window.firebaseDB, 'timeOffRequests', id));
  }catch(e){
    console.error('Error deleting time-off request:', e);
    alert('Error deleting time-off request. Please try again.');
  }
}

// --- Modal Functions ---
function openModal(personName, dateStr, existingRequest = null){
  const modal = document.getElementById('timeoff-modal');
  const title = document.getElementById('modal-title');
  const deleteBtn = document.getElementById('modal-delete');
  
  state.modalState.isOpen = true;
  state.modalState.person = personName || '';
  state.modalState.startDate = dateStr || fmtDateISO(new Date());
  state.modalState.endDate = dateStr || fmtDateISO(new Date());
  state.modalState.coverage = [];
  state.modalState.coverageMode = 'auto';
  state.modalState.editingId = existingRequest ? existingRequest.id : null;
  
  if(existingRequest){
    title.textContent = 'Edit Time Off';
    state.modalState.type = existingRequest.type;
    state.modalState.person = existingRequest.personName;
    state.modalState.startDate = existingRequest.startDate;
    state.modalState.endDate = existingRequest.endDate;
    state.modalState.coverage = existingRequest.coverage || [];
    deleteBtn.style.display = 'block';
  }else{
    title.textContent = 'Add Time Off';
    state.modalState.type = 'vacation';
    deleteBtn.style.display = 'none';
  }
  
  populatePersonSelect();
  updateModalUI();
  modal.classList.add('active');
}

function closeModal(){
  const modal = document.getElementById('timeoff-modal');
  modal.classList.remove('active');
  state.modalState.isOpen = false;
  state.modalState.editingId = null;
}

function populatePersonSelect(){
  const select = document.getElementById('modal-person');
  select.innerHTML = '<option value="">— select person —</option>';
  [...state.fh, ...state.bh].forEach(name=>{
    const opt = document.createElement('option');
    opt.value = name;
    opt.textContent = name;
    if(name === state.modalState.person) opt.selected = true;
    select.appendChild(opt);
  });
}

function updateModalUI(){
  // Update type buttons
  document.querySelectorAll('.type-btn').forEach(btn=>{
    btn.classList.toggle('selected', btn.dataset.type === state.modalState.type);
  });
  
  // Update person select
  document.getElementById('modal-person').value = state.modalState.person;
  
  // Update dates
  document.getElementById('modal-start').value = state.modalState.startDate;
  document.getElementById('modal-end').value = state.modalState.endDate;
  
  // Update coverage mode
  document.querySelectorAll('input[name="coverage-mode"]').forEach(radio=>{
    radio.checked = radio.value === state.modalState.coverageMode;
  });
  
  // Update coverage suggestions
  updateCoverageSuggestions();
}

function updateCoverageSuggestions(){
  const container = document.getElementById('coverage-suggestions');
  container.innerHTML = '';
  
  if(state.modalState.coverageMode === 'none'){
    container.innerHTML = '<span style="font-size:12px;color:var(--text-muted);">Showing scheduled crew only</span>';
    return;
  }
  
  const allPeople = [...state.fh, ...state.bh].filter(p => p !== state.modalState.person);
  const startDate = new Date(state.modalState.startDate);
  const endDate = new Date(state.modalState.endDate);
  
  // Get dates in range
  const dates = [];
  let d = new Date(startDate);
  while(d <= endDate){
    dates.push(new Date(d));
    d.setDate(d.getDate() + 1);
  }
  
  // Find available people for each date
  const availability = {};
  dates.forEach(date => {
    const dateStr = fmtDateISO(date);
    const weekIdx = Math.floor((date - START) / (7 * 24 * 60 * 60 * 1000));
    const dayOfWeek = date.getDay();
    const crew = getCrewForDay(weekIdx, dayOfWeek);
    availability[dateStr] = crew.filter(p => p.name !== state.modalState.person).map(p => p.name);
  });
  
  // Count availability across all dates
  const counts = {};
  allPeople.forEach(p => counts[p] = 0);
  Object.values(availability).forEach(people => {
    people.forEach(p => {
      if(counts[p] !== undefined) counts[p]++;
    });
  });
  
  // Sort by availability (most available first)
  const sorted = allPeople.sort((a,b) => counts[b] - counts[a]);
  
  sorted.forEach(name => {
    const chip = document.createElement('div');
    chip.className = 'coverage-chip';
    if(state.modalState.coverage.includes(name)) chip.classList.add('selected');
    chip.textContent = `${name} (${counts[name]} days)`;
    chip.onclick = () => {
      if(state.modalState.coverage.includes(name)){
        state.modalState.coverage = state.modalState.coverage.filter(c => c !== name);
      }else{
        state.modalState.coverage.push(name);
      }
