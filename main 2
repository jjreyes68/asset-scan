let calSelectedDate = null;

const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const DAY_FULL = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

function fmtDatePretty(dateStr){
  const d = new Date(dateStr + 'T12:00:00');
  return `${DAY_FULL[d.getDay()]}, ${MONTH_NAMES[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
}

function renderCalendar(){
  const grid = document.getElementById('calendar-grid');
  const monthLabel = document.getElementById('cal-month-label');
  grid.innerHTML = '';

  const month = state.calendar.currentMonth;
  const year = state.calendar.currentYear;
  monthLabel.textContent = `${MONTH_NAMES[month]} ${year}`;

  const dayHeaders = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  dayHeaders.forEach(day => {
    const header = document.createElement('div');
    header.className = 'cal-header';
    header.textContent = day;
    grid.appendChild(header);
  });

  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const daysInPrevMonth = new Date(year, month, 0).getDate();
  const today = new Date();
  const todayStr = fmtDateISO(today);

  // Leading empty cells
  for(let i = firstDay - 1; i >= 0; i--){
    const dayEl = document.createElement('div');
    dayEl.className = 'cal-day other-month';
    dayEl.innerHTML = `<div class="cal-day-number">${daysInPrevMonth - i}</div>`;
    grid.appendChild(dayEl);
  }

  for(let day = 1; day <= daysInMonth; day++){
    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const dateObj = new Date(dateStr + 'T12:00:00');
    const weekIdx = Math.floor((dateObj - START) / (7*24*60*60*1000));
    const dayOfWeek = dateObj.getDay();

    const dayEl = document.createElement('div');
    let cls = 'cal-day';
    if(dateStr === todayStr) cls += ' today';
    if(dateStr === calSelectedDate) cls += ' selected';
    dayEl.className = cls;

    const numDiv = document.createElement('div');
    numDiv.className = 'cal-day-number';
    numDiv.textContent = day;
    dayEl.appendChild(numDiv);

    const eventsDiv = document.createElement('div');
    eventsDiv.className = 'cal-day-events';

    if(weekIdx >= 0 && weekIdx < 52){
      const effectiveCrew = getEffectiveCrewForDay(weekIdx, dayOfWeek, dateStr);
      const offToday = state.timeOffRequests.filter(r => r.startDate && r.endDate && dateStr >= r.startDate.trim() && dateStr <= r.endDate.trim());

      // Show first 3 people, then +N more
      const MAX_SHOW = 3;
      effectiveCrew.slice(0, MAX_SHOW).forEach(p => {
        const ev = document.createElement('div');
        if(p.covering){
          ev.className = 'cal-event covering';
          ev.textContent = `${p.name} ↔${p.coveringFor}`;
        } else {
          ev.className = 'cal-event working';
          ev.textContent = `${p.name} ${p.role}`;
        }
        eventsDiv.appendChild(ev);
      });
      if(effectiveCrew.length > MAX_SHOW){
        const more = document.createElement('div');
        more.className = 'cal-more';
        more.textContent = `+${effectiveCrew.length - MAX_SHOW} more`;
        eventsDiv.appendChild(more);
      }
      // Time-off with no cover shown faintly
      offToday.filter(r => !r.coverage || r.coverage.length === 0).forEach(r => {
        const icons = {vacation:'🏖',sick:'🤒',personal:'📅'};
        const ev = document.createElement('div');
        ev.className = `cal-event ${r.type}`;
        ev.textContent = `${icons[r.type]} ${r.personName}`;
        eventsDiv.appendChild(ev);
      });
    }

    dayEl.appendChild(eventsDiv);

    dayEl.addEventListener('click', () => {
      calSelectedDate = dateStr;
      renderCalendar();       // re-render to move selected highlight
      renderDayPanel(dateStr);
    });

    grid.appendChild(dayEl);
  }

  // Trailing cells
  const totalCells = firstDay + daysInMonth;
  const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
  for(let day = 1; day <= remaining; day++){
    const dayEl = document.createElement('div');
    dayEl.className = 'cal-day other-month';
    dayEl.innerHTML = `<div class="cal-day-number">${day}</div>`;
    grid.appendChild(dayEl);
  }

  // Re-render panel if a date is selected
  if(calSelectedDate) renderDayPanel(calSelectedDate);
}

function renderDayPanel(dateStr){
