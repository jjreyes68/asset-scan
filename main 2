function renderTable(){
  const sel=state.selected;
  const tbody=document.getElementById('sched-body');
  tbody.innerHTML='';
  if(!sel){
    tbody.innerHTML=`<tr><td colspan="9" class="empty-state">Pick an operator above to see their full 52-week schedule.</td></tr>`;
    return;
  }

  const half=state.fh.includes(sel)?'fh':'bh';
  const posIdx=state[half].indexOf(sel);
  const off=`<span class="rbadge off">off</span>`;
  const icons={vacation:'🏖️',sick:'🤒',personal:'📅'};

  for(let w=0;w<52;w++){
    const tr=document.createElement('tr');
    if(w%2===1) tr.classList.add('alt');
    const role=getRoleForOp(posIdx,w);
    const rc=ROLE_CLS[role];
    const rb=`<span class="rbadge ${rc}">${role}</span>`;
    const wedOn=hasWed(half,w);

    // Base schedule: which days are scheduled (true) vs off (false)
    const weekStart=getWeekStart(w);
    const baseDays = [0,1,2,3,4,5,6].map(dayIdx => {
      if(half==='fh') return dayIdx===0||dayIdx===1||dayIdx===2||(dayIdx===3&&wedOn);
      else return dayIdx===4||dayIdx===5||dayIdx===6||(dayIdx===3&&wedOn);
    });

    const dayCells=[0,1,2,3,4,5,6].map(dayIdx=>{
      const dayDate=addDays(weekStart, dayIdx);
      const dateStr=fmtDateISO(dayDate);
      const isScheduled=baseDays[dayIdx];
      const timeOff=getTimeOffForPerson(sel, dateStr);
      const extraShifts=getCoverageExtraShifts(sel, dateStr);
      let cellContent;
      let cellClass='clickable';

      if(timeOff){
        // Person is on time-off this day
        cellContent=`<span class="to-badge ${timeOff.type}"><span class="icon">${icons[timeOff.type]}</span>${timeOff.type}</span>`;
      } else if(isScheduled){
        // Normal working day — check if also covering someone
        if(extraShifts.length > 0){
          const coverLabels=extraShifts.map(e=>`<span class="rbadge" style="background:var(--green-light);color:var(--green-dark);margin-top:2px;display:block;">${e.role} covering ${e.coveringFor}</span>`).join('');
          cellContent=`${rb}${coverLabels}`;
        } else {
          cellContent=rb;
        }
      } else if(extraShifts.length > 0){
        // Normally off BUT covering someone — show as a working day
        const coverLabels=extraShifts.map(e=>`<span class="rbadge" style="background:var(--green-light);color:var(--green-dark);">${e.role} covering ${e.coveringFor}</span>`).join('');
        cellContent=`<div style="display:flex;flex-direction:column;gap:2px;">${coverLabels}</div>`;
      } else {
        cellContent=off;
        cellClass='';
      }

      return `<td class="${cellClass}" data-date="${dateStr}">${cellContent}</td>`;
    }).join('');

    tr.innerHTML=`<td class="wk-lbl">Wk ${w+1}</td><td class="date-lbl">${getWeekDates(w)}</td>${dayCells}`;
    tbody.appendChild(tr);
  }

  // Add click handlers to cells
  tbody.querySelectorAll('td.clickable').forEach(td=>{
    td.addEventListener('click', ()=>{
      const dateStr=td.dataset.date;
      const timeOff=getTimeOffForPerson(sel, dateStr);
      openModal(sel, dateStr, timeOff);
    });
  });
}

