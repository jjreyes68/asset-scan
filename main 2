  const effectiveCrew = getEffectiveCrewForDay(weekIdx, dayOfWeek, dateStr);
  const offToday = state.timeOffRequests.filter(r => r.startDate && r.endDate && dateStr >= r.startDate.trim() && dateStr <= r.endDate.trim());
  const icons = {vacation:'🏖️',sick:'🤒',personal:'📅'};

