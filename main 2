// Returns base scheduled crew for a day (ignores time-off/coverage)
// dayOfWeek: 0=Sun,1=Mon,2=Tue,3=Wed,4=Thu,5=Fri,6=Sat
function getCrewForDay(weekIdx, dayOfWeek){
  const crew = [];
  state.fh.forEach((name, posIdx)=>{
    const worksToday =
      dayOfWeek === 0 || dayOfWeek === 1 || dayOfWeek === 2 ||
      (dayOfWeek === 3 && hasWed('fh', weekIdx));
    if(worksToday){
      crew.push({name, role: getRoleForOp(posIdx, weekIdx), half:'fh', covering: false, coveringFor: null});
    }
  });
  state.bh.forEach((name, posIdx)=>{
    const worksToday =
      dayOfWeek === 4 || dayOfWeek === 5 || dayOfWeek === 6 ||
      (dayOfWeek === 3 && hasWed('bh', weekIdx));
    if(worksToday){
      crew.push({name, role: getRoleForOp(posIdx, weekIdx), half:'bh', covering: false, coveringFor: null});
    }
  });
  const roleOrder = {D1:0,D2:1,D3:2,N1:3,N2:4};
  crew.sort((a,b)=> roleOrder[a.role]-roleOrder[b.role]);
  return crew;
}

// Returns the EFFECTIVE crew for a day: removes people on time-off,
// replaces/adds their cover people working that day.
function getEffectiveCrewForDay(weekIdx, dayOfWeek, dateStr){
  const base = getCrewForDay(weekIdx, dayOfWeek);
  const result = [];

  base.forEach(person => {
    const timeOff = getTimeOffForPerson(person.name, dateStr);
    if(timeOff){
      // Person is off — find who is covering them
      const req = state.timeOffRequests.find(r =>
        r.personName === person.name &&
        r.startDate && r.endDate &&
        dateStr >= r.startDate.trim() && dateStr <= r.endDate.trim()
      );
      if(req && req.coverage && req.coverage.length > 0){
        req.coverage.forEach(coverName => {
          // Add cover person in the absent person's role
          result.push({
            name: coverName,
            role: person.role,
            half: person.half,
            covering: true,
            coveringFor: person.name,
            originalOff: timeOff.type
          });
        });
      }
      // The absent person is NOT added to the result (they're off)
    } else {
      result.push(person);
    }
  });

  // De-duplicate: if a cover person appears multiple times (covering multiple people),
  // keep all entries so each covered slot is represented
  const roleOrder = {D1:0,D2:1,D3:2,N1:3,N2:4};
  result.sort((a,b)=> roleOrder[a.role]-roleOrder[b.role]);
  return result;
}

// For a given person on a given date: are they working an EXTRA day (covering someone)?
// Returns array of {personName, role, type} they are covering, if any, even on their scheduled off days
function getCoverageExtraShifts(personName, dateStr){
  const extras = [];
  state.timeOffRequests.forEach(req => {
    if(req.startDate && req.endDate && dateStr >= req.startDate.trim() && dateStr <= req.endDate.trim()){
      if(req.coverage && req.coverage.includes(personName)){
        // Find the role of the absent person on this date
        const dateObj = new Date(dateStr + 'T12:00:00');
        const weekIdx = Math.floor((dateObj - START) / (7 * 24 * 60 * 60 * 1000));
        const half = state.fh.includes(req.personName) ? 'fh' : 'bh';
        const posIdx = state[half].indexOf(req.personName);
        const role = posIdx >= 0 ? getRoleForOp(posIdx, weekIdx) : '?';
        extras.push({ coveringFor: req.personName, role, type: req.type });
      }
    }
  });
  return extras;
}

// --- Drag & drop ---
let dragging=null, dragSourceHalf=null, dragOverChip=null;

function renderChips(){
  ['fh','bh'].forEach(half=>{
    const zone = document.getElementById(`zone-${half}`);
    zone.innerHTML='';
    state[half].forEach((name,idx)=>{
      const role = ROLES[idx%5];
      const chip = document.createElement('div');
      chip.className=`chip ${half}-chip`;
      chip.draggable=true;
      chip.dataset.name=name; chip.dataset.half=half;
      chip.innerHTML=`<span class="chip-pos">${idx+1}</span><span class="chip-name">${name}</span><span class="chip-role role-${ROLE_CLS[role]}">${role}</span>`;
      chip.addEventListener('dragstart',e=>{
        dragging=name; dragSourceHalf=half;
        setTimeout(()=>chip.classList.add('dragging'),0);
        e.dataTransfer.effectAllowed='move';
      });
      chip.addEventListener('dragend',()=>{
        chip.classList.remove('dragging');
        dragging=null; dragSourceHalf=null; dragOverChip=null;
        document.querySelectorAll('.drop-zone').forEach(z=>z.classList.remove('drag-over'));
        renderChips();
      });
      chip.addEventListener('dragover',e=>{ e.preventDefault(); dragOverChip={name,half}; });
      zone.appendChild(chip);
    });
    zone.addEventListener('dragover',e=>{ e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave',()=>zone.classList.remove('drag-over'));
    zone.addEventListener('drop',e=>{
      e.preventDefault(); zone.classList.remove('drag-over');
      if(!dragging) return;
      state.fh=state.fh.filter(n=>n!==dragging);
      state.bh=state.bh.filter(n=>n!==dragging);
      const arr=state[half];
      if(dragOverChip && dragOverChip.half===half && dragOverChip.name!==dragging){
        const at=arr.indexOf(dragOverChip.name);
        if(at>=0) arr.splice(at,0,dragging); else arr.push(dragging);
      } else { arr.push(dragging); }
      dragOverChip=null;
      renderChips(); updateSelect(); renderCrewGrid();
    });
  });
  updateSelect();
  renderCrewGrid();
}

